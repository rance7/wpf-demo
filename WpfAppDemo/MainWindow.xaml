<Window x:Class="WpfAppDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppDemo"
        mc:Ignorable="d"
        Title="Modbus TCP 设备数据采集" Height="500" Width="800">
    <Window.Resources>
        <local:MainWindowViewModel x:Key="ViewModel"/>
    </Window.Resources>
    <Grid Background="#F5F5F5" DataContext="{StaticResource ViewModel}">
        <StackPanel Margin="20" VerticalAlignment="Top">
            <!-- 连接配置 -->
            <GroupBox Header="连接配置" Padding="10" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Content="主机地址:" VerticalAlignment="Center"/>
                    <TextBox x:Name="HostTextBox" Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Padding="5" VerticalAlignment="Center" IsEnabled="{Binding HostTextBoxEnabled}"/>

                    <Label Grid.Column="2" Content="端口:" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <TextBox x:Name="PortTextBox" Grid.Column="3" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Padding="5" VerticalAlignment="Center" IsEnabled="{Binding PortTextBoxEnabled}"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ConnectButton" Content="连接" Command="{Binding ConnectAsyncCommand}" Padding="15,5" Margin="10,0,5,0" Background="#4CAF50" Foreground="White" IsEnabled="{Binding ConnectButtonEnabled}"/>
                        <Button x:Name="DisconnectButton" Content="断开" Command="{Binding DisconnectCommand}" Padding="15,5" Background="#F44336" Foreground="White" IsEnabled="{Binding DisconnectButtonEnabled}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 设备数据显示 -->
            <GroupBox Header="设备数据" Padding="10" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="温度:" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TemperatureBlock" Text="{Binding Temperature}" FontSize="14" Foreground="#2196F3" Padding="5"/>

                    <Label Grid.Row="0" Grid.Column="2" Content="湿度:" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" x:Name="HumidityBlock" Text="{Binding Humidity}" FontSize="14" Foreground="#2196F3" Padding="5"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="气压:" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PressureBlock" Text="{Binding Pressure}" FontSize="14" Foreground="#2196F3" Padding="5"/>

                    <Label Grid.Row="1" Grid.Column="2" Content="状态:" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" x:Name="StatusBlock" Text="{Binding Status}" FontSize="14" Foreground="{Binding StatusForeground}" Padding="5"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="最后更新:" FontSize="12"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" x:Name="LastUpdateBlock" Text="{Binding LastUpdate}" FontSize="12" Foreground="#666" Padding="5"/>
                </Grid>
            </GroupBox>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button x:Name="ReadButton" Content="读取数据" Command="{Binding ReadAsyncCommand}" Padding="20,10" Margin="0,0,10,0" Background="#2196F3" Foreground="White" IsEnabled="{Binding ReadButtonEnabled}"/>
                <Button x:Name="ClearButton" Content="清空数据" Command="{Binding ClearCommand}" Padding="20,10" Background="#9C27B0" Foreground="White"/>
                <TextBlock x:Name="MessageBlock" Text="{Binding Message}" Foreground="{Binding MessageForeground}" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>